# ─── Firehose ────────────────────────────────────────────────────────────────
# Get from https://firehose.com dashboard
# Used by: apps/listener
FIREHOSE_TAP_TOKEN=fh_your_tap_token_here
# Or use a management key to create a new tap:
# FIREHOSE_MANAGEMENT_KEY=fhm_your_management_key_here

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Get from your Supabase project → Settings → API
SUPABASE_URL=https://your-project.supabase.co

# Public anon key — safe to expose in browser (used by Next.js frontend)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your_anon_key

# Service role key — KEEP SECRET, never expose in browser (used by listener + API routes)
SUPABASE_SERVICE_ROLE_KEY=eyJ...your_service_role_key
